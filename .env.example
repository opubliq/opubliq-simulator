# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Gemini API key for ingestion scripts (generate_embeddings.py)
GEMINI_API_KEY=your-gemini-api-key-here

# Note: For the frontend/Edge Function, the Gemini key is entered by the user directly in the UI

# Local rclone Google Drive mount (required for ingestion scripts)
# Mount with: rclone mount gdrive: ~/opubliq/gdrive --daemon
SHARED_FOLDER_PATH=/home/your-user/opubliq/gdrive/_SharedFolder_data_produit
