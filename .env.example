# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Note: Gemini API key is entered by the user directly in the UI (not a project config)

# Local rclone Google Drive mount (required for ingestion scripts)
# Mount with: rclone mount gdrive: ~/opubliq/gdrive --daemon
SHARED_FOLDER_PATH=/home/your-user/opubliq/gdrive/_SharedFolder_data_produit
